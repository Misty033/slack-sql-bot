# ========================
# Slack credentials
# ========================

# Bot token for your Slack app
# Example: xxxxxxxxxxxxxxxxxxxxx
SLACK_BOT_TOKEN=

# Signing secret from your Slack app settings
SLACK_SIGNING_SECRET=

# ========================
# Gemini API
# ========================

# API key to access Gemini services
# Example: gemini_abcdef123456
GEMINI_API_KEY=

# ========================
# Database configuration
# ========================

# Database host (e.g., localhost, db.example.com)
DB_HOST=

# Database port (default for PostgreSQL: 5432)
DB_PORT=

# Name of the database to connect to
DB_NAME=

# Username to access the database
DB_USER=

# Password for the database user
DB_PASSWORD=
